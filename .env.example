# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=your_random_64_char_hex_here

# ─── Database ────────────────────────────────────────────────────────────────
# On Railway: mount a persistent disk at /data and set this to /data/db.sqlite
# Locally: leave empty (defaults to ./db.sqlite)
DATABASE_PATH=/data/db.sqlite

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
# On first boot, if no super_admin exists, one is created with these credentials.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# ─── App URL ─────────────────────────────────────────────────────────────────
# Full public URL of the deployed app (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-app.up.railway.app

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxx
# Optional: your Paystack subaccount code (from Paystack Dashboard > Subaccounts).
# When set, every payment (appointments, orders, custom orders) keeps a flat
# ₦1,000 on the main account and settles the remainder to this subaccount.
# Leave unset to keep 100% of every payment on the main account.
PAYSTACK_SUBACCOUNT_CODE=ACCT_xxxx

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
# Must be a domain verified in your Resend account, or all emails will be
# rejected with "Domain not verified".
EMAIL_FROM=DB Prosthetics <noreply@dbpando.com>
# Receives order/payment notifications and unhandled-error alerts.
SUPER_ADMIN_EMAIL=admin@dbpando.com

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
